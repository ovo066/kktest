VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Optional: protect /api/push-send. If empty, endpoint accepts unauthenticated requests.
PUSH_SERVER_TOKEN=
# Optional: extra upstream hosts allowed by /api/proxy on Vercel, comma-separated.
# Also used by MCP bridge proxy fallback for deployed HTTPS/PWA clients.
# Example: API_PROXY_ALLOWED_HOSTS=api.mortis.edu.kg,api.openai.com,bridge.example.com
API_PROXY_ALLOWED_HOSTS=

# Optional: enable Discord-based access control for deployed shared links.
# When enabled, users must finish Discord OAuth before the app boots.
# Add the callback URL to your Discord application, usually:
# https://your-domain.vercel.app/api/access-discord-callback
ACCESS_GUARD_ENABLED=
ACCESS_GUARD_SESSION_SECRET=
ACCESS_GUARD_SESSION_MAX_AGE_SECONDS=
ACCESS_GUARD_ADMIN_CODE=
ACCESS_GUARD_ADMIN_LABEL=
ACCESS_GUARD_DEVICE_SLOT_LIMIT=3
ACCESS_GUARD_STORAGE_PREFIX=
ACCESS_GUARD_ANNOUNCEMENT_JSON=
ACCESS_GUARD_ANNOUNCEMENT_KEY=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
DISCORD_GUILD_IDS=
# Advanced optional rules for multiple communities / roles.
# JSON array, any rule matched => allow access.
# Example:
# DISCORD_ACCESS_RULES_JSON=[{"guildId":"111","label":"主社区会员","roleIds":["aaa","bbb"]},{"guildId":"222","label":"分社区管理组","roleIds":["ccc"]},{"guildId":"333","label":"公开社区","roleIds":[]}]
DISCORD_ACCESS_RULES_JSON=
DISCORD_REDIRECT_URI=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: pre-bundle Firebase config for cloud sync.
# If you fill these before build/deploy, end users only need to enable cloud sync;
# they do not need to manually paste Firebase project settings in the UI.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=
